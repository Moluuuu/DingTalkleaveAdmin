# leaveAdmin runtime environment example
# Copy to .env or export these variables in systemd before deployment.

# Admin UI/API password used by X-Auth. Change this before exposing the service.
LEAVEADMIN_AUTH_PASSWORD=change-me

# Optional runtime home. Defaults to the repository root when running from source.
# LEAVEADMIN_HOME=/opt/leaveadmin
# LEAVEADMIN_DB_PATH=/opt/leaveadmin/admin.db
# LEAVEADMIN_CONFIG=/opt/leaveadmin/config.json
# LEAVEADMIN_CONSTANTS=/opt/leaveadmin/constants.yaml

# Optional DingTalk robot notification target. Leave empty to disable notifications.
DINGTALK_NOTIFY_USERID=
DINGTALK_ROBOT_CODE=

# Emergency restore defaults. Prefer passing these explicitly in the GUI/CLI.
DINGTALK_LEAVE_CODE=
DINGTALK_OP_USERID=
